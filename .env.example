# Copy this file to .env before startup.
# start.bat will create .env from this template automatically when .env is missing.

# Web
VITE_API_BASE_URL=http://localhost:8080

# MySQL inside Docker Compose
MYSQL_USER=root
MYSQL_PASSWORD=root

# Retrieval
MILVUS_COLLECTION=knowledge_chunk_vectors_bge_m3
EMBEDDING_DIMENSION=1024
RAG_TOP_K=5
RAG_CANDIDATE_K=20
RAG_SIMILARITY_THRESHOLD=0.2
RAG_HISTORY_LIMIT=8

# Rerank. Keep local for a dependency-light demo.
RERANK_PROVIDER=local
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_FAIL_OPEN=true

# Agent mode
AGENT_MOCK=false

# LLM. API keys can also be configured from the frontend settings page after startup.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=
DEEPSEEK_API_KEY=
LLM_THINKING=false

# Embedding. SiliconFlow bge-m3 uses 1024 dimensions.
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
SILICONFLOW_API_KEY=
